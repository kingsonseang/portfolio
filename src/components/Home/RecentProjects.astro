---
import { projects } from "@/data/projects";
---

<section class="px-6 pb-16 md:px-8 lg:px-10 xl:px-12">
  <div class="mb-10 flex items-end justify-between">
    <div>
      <p class="text-secondary/40 mb-1 text-xs font-medium tracking-widest uppercase">
        Selected work
      </p>
      <h2 class="text-secondary text-2xl font-semibold md:text-3xl">Recent Projects</h2>
    </div>
    <a
      href="/projects"
      class="text-secondary/50 hover:text-secondary group flex items-center gap-1.5 text-sm transition-colors duration-200"
    >
      View all
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform duration-200 group-hover:translate-x-1"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project) => (
        <a
          href={`/projects?active_project=${project.id}`}
          data-project-id={project.id}
          class="project-card group relative flex flex-col overflow-hidden rounded-3xl bg-white/60 p-6 transition-all duration-300 hover:-translate-y-1 hover:bg-white/90 hover:shadow-xl hover:shadow-black/5"
          style={`--accent: ${project.color};`}
        >
          {/* Accent bar */}
          <div
            class="mb-5 h-1 w-10 rounded-full transition-all duration-300 group-hover:w-16"
            style={`background-color: ${project.color};`}
          />

          {/* Header */}
          <div class="mb-3 flex items-start justify-between gap-2">
            <h3 class="text-secondary text-lg leading-tight font-semibold">{project.title}</h3>
            <span class="text-secondary/30 shrink-0 text-sm">{project.year}</span>
          </div>

          {/* Type badge */}
          <span
            class="mb-4 inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-xs font-medium capitalize"
            style={`background-color: ${project.color}18; color: ${project.color};`}
          >
            {project.type}
          </span>

          {/* Overview */}
          <p class="text-secondary/55 mb-5 line-clamp-2 flex-1 text-sm leading-relaxed">
            {project.overview}
          </p>

          {/* Tech stack */}
          <div class="flex flex-wrap gap-1.5">
            {project.tech_stack.slice(0, 4).map((tech) => (
              <span class="text-secondary/50 rounded-full bg-black/5 px-2.5 py-1 text-xs">
                {tech.name}
              </span>
            ))}
            {project.tech_stack.length > 4 && (
              <span class="text-secondary/30 rounded-full bg-black/5 px-2.5 py-1 text-xs">
                +{project.tech_stack.length - 4}
              </span>
            )}
          </div>

          {/* Footer link */}
          <div class="mt-5 flex items-center gap-1 border-t border-black/5 pt-4">
            <span class="text-secondary/35 text-xs">{project.url}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="11"
              height="11"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary/25 ml-auto opacity-0 transition-opacity duration-200 group-hover:opacity-100"
            >
              <path d="M7 7h10v10" />
              <path d="M7 17 17 7" />
            </svg>
          </div>
        </a>
      ))
    }
  </div>
</section>
