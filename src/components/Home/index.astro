---
import Header from "./Header";
import Clients from "./Clients.astro";
import { AnimatedButton } from "@/components/ui/animated-button";
import { Image } from 'astro:assets';

const currentPath = Astro.url.pathname;
---

<div class="rounded-[4rem] bg-[#f5f5f5]">
  <div
    class="flex min-h-[70svh] flex-col space-y-10 rounded-[4rem] bg-[#ebebeb] p-6 md:p-8 lg:p-10 xl:p-12"
  >
    <Header currentPath={currentPath} client:load />

    <div
      class="mx-auto flex max-w-2xl flex-1 flex-col items-center justify-center space-y-8 py-8 text-center"
    >
      <div class="group relative">
        <div class="size-32 rounded-full ring-4 ring-white overflow-clip">
          <Image
            src="/images/headshot.png"
            alt="Solomon Momoh's headshot"
            width={200}
            height={200}
            class="w-full h-full object-cover grayscale-75 "
          />
        </div>
        <div class="absolute top-6 -right-28 -rotate-12">
          <AnimatedButton size="sm" className="peer text-xs select-none" client:load>Solomon Momoh 👋🏾</AnimatedButton>
        </div>
      </div>
      <p
        class="from-secondary bg-gradient-to-br from-50% to-transparent bg-clip-text text-3xl text-transparent md:text-4xl lg:text-5xl xl:text-6xl"
      >
        Building digital products, brands, and experience.
      </p>
      <AnimatedButton variant="secondary" client:load>See latest projects</AnimatedButton>
    </div>
  </div>

    <Clients />
</div>
