---
import Header from "./Header";
import Clients from "./Clients.astro";
import RecentProjects from "./RecentProjects.astro";
import { AnimatedButton } from "@/components/ui/animated-button";
import { AnimatedSection } from "@/components/AnimatedSection";
import { Image } from "astro:assets";

const currentPath = Astro.url.pathname;
---

<div class="rounded-[4rem] bg-[#f5f5f5]">
  <div
    class="flex min-h-[70svh] flex-col space-y-10 rounded-[4rem] bg-[#ebebeb] p-6 md:p-8 lg:p-10 xl:p-12"
  >
    <Header currentPath={currentPath} client:load />

    <div
      class="mx-auto flex max-w-2xl flex-1 flex-col items-center justify-center space-y-8 py-8 text-center"
    >
      <AnimatedSection delay={0} client:load>
        <div class="group relative mb-8">
          <div class="size-32 overflow-clip rounded-full ring-4 ring-white">
            <Image
              src="/images/headshot.png"
              alt="Solomon Momoh's headshot"
              width={200}
              height={200}
              class="h-full w-full object-cover grayscale-75"
            />
          </div>
          <div class="absolute top-6 -right-28 -rotate-12">
            <AnimatedButton size="sm" className="peer text-xs select-none" client:load
              >Solomon Momoh 👋🏾</AnimatedButton
            >
          </div>
        </div>
      </AnimatedSection>

      <AnimatedSection delay={0.1} client:load>
        <p
          class="from-secondary mb-8 bg-gradient-to-br from-50% to-transparent bg-clip-text text-3xl text-transparent md:text-4xl lg:text-5xl xl:text-6xl"
        >
          Building digital products, brands, and experience.
        </p>
      </AnimatedSection>

      <AnimatedSection delay={0.2} client:load>
        <AnimatedButton variant="secondary" client:load>See latest projects</AnimatedButton>
      </AnimatedSection>
    </div>
  </div>

  <AnimatedSection delay={0} direction="none" client:load>
    <Clients />
  </AnimatedSection>

  <AnimatedSection delay={0} direction="up" client:load>
    <RecentProjects />
  </AnimatedSection>
</div>
