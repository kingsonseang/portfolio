---
import LogoLoop from "@/components/LogoLoop";

const clientLogos = [
  {
    src: "https://sparkafrica.co/favicon.ico",
    alt: "Spark Africa Logo",
    href: "https://sparkafrica.co",
  },
  {
    src: "https://africatechnologyexpo.com/api/media/file/00002gv80vofw",
    alt: "Africa Technology Expo Logo",
    href: "https://africatechnologyexpo.com",
  },
  {
    src: "https://pub-5bc531ab234d403db97c2b4470914291.r2.dev/africa-technology-expo/africa-startup-festival/asf-white-logo-00000dkeb022a.png",
    alt: "Africa Startup Festival Logo",
    href: "https://africastartupfestival.com",
  },
  {
    src: "/images/bolefestival_logo.webp",
    alt: "Bole Festival Logo",
    href: "https://bolefestival.com",
  },
  { src: "/images/straqa_logo.webp", alt: "Straqa Logo", href: "https://usestraqa.com/" },
];
---

<div class="p-6 md:p-8 lg:p-10 xl:p-16">
  <LogoLoop
    logos={clientLogos}
    speed={120}
    direction="left"
    logoHeight={48}
    gap={80}
    pauseOnHover
    scaleOnHover
    fadeOut
    fadeOutColor="#f5f5f5"
    ariaLabel="Logos of companies I've worked with over the years"
    client:load
  />
</div>
